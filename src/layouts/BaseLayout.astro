---
import { siteMeta } from "../config/site.js";
import { withBase } from "../lib/paths.js";

const { title = siteMeta.title, description = siteMeta.description } =
  Astro.props;

const pageTitle =
  title === siteMeta.title ? title : `${title} | ${siteMeta.title}`;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.href;
const navigation = [
  { href: withBase(), label: "Ana Sayfa" },
  { href: withBase("arsiv/"), label: "Arşiv" },
  { href: withBase("rss.xml"), label: "RSS" },
];

function isActive(href) {
  return Astro.url.pathname === new URL(href, Astro.url).pathname;
}
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f3ecdf" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-shell">
      <div class="orb orb-one"></div>
      <div class="orb orb-two"></div>
      <header class="site-header container">
        <a class="brand" href={withBase()}>
          <span class="brand__mark">B</span>
          <span>
            <strong>{siteMeta.title}</strong>
            <small>{siteMeta.tagline}</small>
          </span>
        </a>
        <nav class="nav">
          {
            navigation.map((item) => (
              <a
                class:list={[
                  "nav__link",
                  { "nav__link--active": isActive(item.href) },
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>

      <main class="container main-content">
        <slot />
      </main>

      <footer class="site-footer container">
        <p>
          Bülten, Burak KUTBAY tarafından AI ile hazırlandı. İçerik otomatik
          derlenir ve düzenlenir. Proje
          <strong>
            <a
              href="https://github.com/brkse/bulten"
              style="display: inline-flex; align-items: center; gap: 0.35rem;"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2.02c-3.2.7-3.88-1.54-3.88-1.54-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.47.11-3.07 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.6.23 2.78.11 3.07.73.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.39-5.25 5.67.41.36.77 1.06.77 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
                ></path>
              </svg>
              GitHub
            </a>
          </strong>
          üzerinde yer alır.
        </p>
        <div class="footer-links">
          <a href={withBase("rss.xml")}>Global RSS</a>
          <a href={withBase("opml.xml")}>OPML</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f3ecdf;
    --bg-soft: #fbf6ec;
    --panel: rgba(255, 251, 243, 0.88);
    --panel-strong: rgba(255, 253, 249, 0.96);
    --line: rgba(58, 46, 31, 0.12);
    --line-strong: rgba(58, 46, 31, 0.18);
    --text: #24303a;
    --text-strong: #141b22;
    --muted: #5f655f;
    --warm: #c96c45;
    --cool: #2f7d74;
    --shadow: 0 24px 60px rgba(79, 56, 24, 0.08);
    --shadow-soft: 0 16px 36px rgba(79, 56, 24, 0.07);
    --radius-lg: 32px;
    --radius-md: 22px;
    --radius-sm: 16px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background:
      radial-gradient(
        circle at top left,
        rgba(201, 108, 69, 0.13),
        transparent 36%
      ),
      radial-gradient(
        circle at top right,
        rgba(47, 125, 116, 0.12),
        transparent 34%
      ),
      linear-gradient(180deg, #f8f2e8 0%, #efe6d7 100%);
    min-height: 100%;
  }

  body {
    margin: 0;
    color: var(--text);
    font-family: "Space Grotesk", sans-serif;
    background: transparent;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  code,
  pre {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .page-shell {
    position: relative;
    min-height: 100vh;
    overflow-x: clip;
  }

  .orb {
    position: fixed;
    inset: auto;
    width: 24rem;
    height: 24rem;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(70px);
    opacity: 0.55;
    z-index: 0;
  }

  .orb-one {
    top: -6rem;
    right: -3rem;
    background: rgba(201, 108, 69, 0.22);
  }

  .orb-two {
    bottom: -8rem;
    left: -5rem;
    background: rgba(47, 125, 116, 0.18);
  }

  .container {
    width: min(1180px, calc(100vw - 2rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1.35rem 0 0.85rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
  }

  .brand strong {
    display: block;
    font-size: 1rem;
    letter-spacing: 0.02em;
    color: var(--text-strong);
  }

  .brand small {
    display: block;
    color: var(--muted);
    font-size: 0.75rem;
  }

  .brand__mark {
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    border-radius: 18px;
    background: linear-gradient(
      135deg,
      rgba(201, 108, 69, 0.96),
      rgba(47, 125, 116, 0.96)
    );
    color: #fff8f0;
    font-weight: 700;
    box-shadow: var(--shadow-soft);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .nav__link {
    padding: 0.7rem 1rem;
    border-radius: 999px;
    color: var(--muted);
    border: 1px solid transparent;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--text-strong);
    border-color: var(--line-strong);
    background: rgba(255, 255, 255, 0.5);
    transform: translateY(-1px);
  }

  .main-content {
    padding: 1.2rem 0 4rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    backdrop-filter: blur(14px);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
  }

  .eyebrow::before {
    content: "";
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--warm), var(--cool));
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    color: var(--text-strong);
    background: rgba(255, 255, 255, 0.56);
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--cool) 32%, var(--line-strong));
    background: rgba(255, 255, 255, 0.82);
    box-shadow: var(--shadow-soft);
  }

  .button--primary {
    border-color: transparent;
    background: linear-gradient(
      135deg,
      rgba(201, 108, 69, 0.96),
      rgba(47, 125, 116, 0.92)
    );
    color: #fff7ef;
    font-weight: 700;
  }

  .meta-row,
  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .meta-pill,
  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.82rem;
  }

  .section-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1rem;
  }

  .section-title h2 {
    margin: 0;
    font-size: clamp(1.6rem, 2vw, 2.2rem);
    color: var(--text-strong);
  }

  .section-title p {
    margin: 0;
    color: var(--muted);
    max-width: 42rem;
  }

  .grid-two {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .grid-three {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0 0 2.5rem;
    color: var(--muted);
  }

  .site-footer p {
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .prose {
    font-family: "Newsreader", serif;
    font-size: clamp(1.14rem, 1.05rem + 0.28vw, 1.3rem);
    line-height: 1.9;
    color: #2a343d;
  }

  .prose :is(h1, h2, h3, h4) {
    color: var(--text-strong);
    line-height: 1.12;
    scroll-margin-top: 6rem;
  }

  .prose h1 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .prose h2 {
    font-size: clamp(1.7rem, 2vw, 2.15rem);
    margin-top: 2.4rem;
  }

  .prose h3 {
    font-size: 1.35rem;
    margin-top: 1.8rem;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin: 1.05rem 0;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.15rem;
  }

  .prose li + li {
    margin-top: 0.45rem;
  }

  .prose a {
    color: var(--cool);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--cool) 30%, transparent);
    text-underline-offset: 0.16em;
  }

  .prose blockquote {
    margin-left: 0;
    padding: 1rem 1.1rem;
    border-left: 3px solid rgba(201, 108, 69, 0.7);
    border-radius: 0 18px 18px 0;
    background: rgba(201, 108, 69, 0.08);
  }

  .prose code {
    font-size: 0.92rem;
    padding: 0.08rem 0.35rem;
    border-radius: 0.45rem;
    background: rgba(47, 125, 116, 0.08);
  }

  .prose pre {
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    overflow-x: auto;
    background: #1a2430;
    border: 1px solid rgba(19, 28, 39, 0.18);
    color: #eef3fb;
  }

  @media (max-width: 920px) {
    .grid-two,
    .grid-three {
      grid-template-columns: 1fr;
    }

    .site-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .container {
      width: min(100vw - 1rem, 1180px);
    }

    .main-content {
      padding-top: 0.75rem;
    }
  }
</style>
