---
import { siteMeta } from "../config/site.js";
import { withBase } from "../lib/paths.js";

const { title = siteMeta.title, description = siteMeta.description } =
  Astro.props;

const pageTitle =
  title === siteMeta.title ? title : `${title} | ${siteMeta.title}`;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.href;
const navigation = [
  { href: withBase(), label: "Ana Sayfa" },
  { href: withBase("arsiv/"), label: "Arşiv" },
  { href: withBase("rss.xml"), label: "RSS" },
];

function isActive(href) {
  return Astro.url.pathname === new URL(href, Astro.url).pathname;
}
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#09090b" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-shell">
      <div class="orb orb-one"></div>
      <div class="orb orb-two"></div>
      <header class="site-header container">
        <a class="brand" href={withBase()}>
          <span class="brand__mark">B</span>
          <span>
            <strong>{siteMeta.title}</strong>
            <small>{siteMeta.tagline}</small>
          </span>
        </a>
        <nav class="nav">
          {
            navigation.map((item) => (
              <a
                class:list={[
                  "nav__link",
                  { "nav__link--active": isActive(item.href) },
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>

      <main class="container main-content">
        <slot />
      </main>

      <footer class="site-footer container">
        <p>
          Bülten, Burak KUTBAY tarafından AI ile hazırlandı. İçerik otomatik
          derlenir ve düzenlenir. Proje
          <strong>
            <a
              href="https://github.com/brkse/bulten"
              style="display: inline-flex; align-items: center; gap: 0.35rem;"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2.02c-3.2.7-3.88-1.54-3.88-1.54-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.47.11-3.07 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.6.23 2.78.11 3.07.73.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.39-5.25 5.67.41.36.77 1.06.77 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
                ></path>
              </svg>
              GitHub
            </a>
          </strong>
          üzerinde yer alır.
        </p>
        <!-- <div class="footer-links">
          <a href={withBase("rss.xml")}>Global RSS</a>
          <a href={withBase("opml.xml")}>OPML</a>
        </div> -->
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #09090b;
    --bg-subtle: #131316;
    --surface: rgba(255, 255, 255, 0.035);
    --surface-hover: rgba(255, 255, 255, 0.065);
    --panel: rgba(255, 255, 255, 0.04);
    --panel-strong: rgba(255, 255, 255, 0.06);
    --line: rgba(255, 255, 255, 0.07);
    --line-strong: rgba(255, 255, 255, 0.12);
    --text: #d4d4d8;
    --text-strong: #fafafa;
    --muted: #71717a;
    --warm: #f97316;
    --cool: #22d3ee;
    --accent-1: #818cf8;
    --accent-2: #34d399;
    --gradient-accent: linear-gradient(135deg, #818cf8, #22d3ee);
    --gradient-warm: linear-gradient(135deg, #f97316, #ef4444);
    --shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
    --shadow-soft: 0 8px 32px rgba(0, 0, 0, 0.25);
    --shadow-glow: 0 0 60px rgba(129, 140, 248, 0.08);
    --radius-xl: 28px;
    --radius-lg: 22px;
    --radius-md: 16px;
    --radius-sm: 10px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background: var(--bg);
    min-height: 100%;
  }

  body {
    margin: 0;
    color: var(--text);
    font-family:
      "Inter",
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    background: transparent;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  code,
  pre {
    font-family:
      "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      monospace;
  }

  .page-shell {
    position: relative;
    min-height: 100vh;
    overflow-x: clip;
  }

  .orb {
    position: fixed;
    inset: auto;
    width: 40rem;
    height: 40rem;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(130px);
    opacity: 0.12;
    z-index: 0;
  }

  .orb-one {
    top: -15rem;
    right: -10rem;
    background: var(--accent-1);
  }

  .orb-two {
    bottom: -20rem;
    left: -12rem;
    background: var(--cool);
  }

  .container {
    width: min(1200px, calc(100vw - 2rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1.5rem 0 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    transition: opacity 200ms ease;
  }

  .brand:hover {
    opacity: 0.8;
  }

  .brand strong {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-strong);
  }

  .brand small {
    display: block;
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  .brand__mark {
    width: 2.6rem;
    height: 2.6rem;
    display: grid;
    place-items: center;
    border-radius: 14px;
    background: var(--gradient-accent);
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    box-shadow:
      0 0 20px rgba(129, 140, 248, 0.3),
      var(--shadow-soft);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0.3rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--line);
  }

  .nav__link {
    padding: 0.6rem 1rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 500;
    border: 1px solid transparent;
    transition:
      color 200ms ease,
      background 200ms ease,
      border-color 200ms ease;
  }

  .nav__link:hover {
    color: var(--text-strong);
    background: var(--surface-hover);
  }

  .nav__link--active {
    color: var(--text-strong);
    background: var(--surface-hover);
    border-color: var(--line-strong);
  }

  .main-content {
    padding: 1.5rem 0 5rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition:
      border-color 250ms ease,
      box-shadow 250ms ease;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
  }

  .eyebrow::before {
    content: "";
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--gradient-accent);
    box-shadow: 0 0 8px rgba(129, 140, 248, 0.4);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.2rem;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    color: var(--text);
    background: var(--surface);
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    transition:
      transform 200ms ease,
      border-color 200ms ease,
      background 200ms ease,
      box-shadow 200ms ease,
      color 200ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    background: var(--surface-hover);
    color: var(--text-strong);
    box-shadow: var(--shadow-soft);
  }

  .button--primary {
    border-color: transparent;
    background: var(--gradient-accent);
    color: #fff;
    font-weight: 600;
  }

  .button--primary:hover {
    box-shadow: 0 0 30px rgba(129, 140, 248, 0.25);
    transform: translateY(-1px);
  }

  .meta-row,
  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .meta-pill,
  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.65rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 500;
  }

  .section-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1.25rem;
  }

  .section-title h2 {
    margin: 0;
    font-size: clamp(1.5rem, 2vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-strong);
  }

  .section-title p {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    max-width: 42rem;
  }

  .grid-two {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .grid-three {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.85rem;
  }

  .site-footer p {
    margin: 0;
    line-height: 1.7;
  }

  .site-footer a {
    color: var(--text);
    transition: color 200ms ease;
  }

  .site-footer a:hover {
    color: var(--accent-1);
  }

  .footer-links {
    display: flex;
    gap: 1rem;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .prose {
    font-family: "Inter", sans-serif;
    font-size: clamp(1.05rem, 1rem + 0.2vw, 1.18rem);
    line-height: 1.85;
    color: var(--text);
  }

  .prose :is(h1, h2, h3, h4) {
    font-family: "Fraunces", serif;
    color: var(--text-strong);
    line-height: 1.15;
    letter-spacing: -0.02em;
    scroll-margin-top: 6rem;
  }

  .prose h1 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .prose h2 {
    font-size: clamp(1.6rem, 2vw, 2rem);
    margin-top: 2.8rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
  }

  .prose h3 {
    font-size: 1.3rem;
    margin-top: 2rem;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin: 1.1rem 0;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.2rem;
  }

  .prose li + li {
    margin-top: 0.5rem;
  }

  .prose li::marker {
    color: var(--accent-1);
  }

  .prose a {
    color: var(--accent-1);
    text-decoration: underline;
    text-decoration-color: rgba(129, 140, 248, 0.3);
    text-underline-offset: 0.18em;
    transition: text-decoration-color 200ms ease;
  }

  .prose a:hover {
    text-decoration-color: var(--accent-1);
  }

  .prose blockquote {
    margin-left: 0;
    padding: 1rem 1.2rem;
    border-left: 3px solid var(--accent-1);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    background: rgba(129, 140, 248, 0.06);
    color: var(--text);
  }

  .prose code {
    font-size: 0.88rem;
    padding: 0.12rem 0.4rem;
    border-radius: 6px;
    background: var(--surface-hover);
    border: 1px solid var(--line);
    color: var(--cool);
  }

  .prose pre {
    padding: 1.2rem 1.3rem;
    border-radius: var(--radius-md);
    overflow-x: auto;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--line);
    color: #e4e4e7;
  }

  .prose pre code {
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
  }

  .prose strong {
    color: var(--text-strong);
    font-weight: 600;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }

  .gradient-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (max-width: 920px) {
    .grid-two,
    .grid-three {
      grid-template-columns: 1fr;
    }

    .site-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .container {
      width: min(100vw - 1rem, 1200px);
    }

    .main-content {
      padding-top: 0.75rem;
    }
  }
</style>
