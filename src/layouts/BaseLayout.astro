---
import { siteMeta } from "../config/site.js";
import { withBase } from "../lib/paths.js";

const { title = siteMeta.title, description = siteMeta.description } =
  Astro.props;

const pageTitle =
  title === siteMeta.title ? title : `${title} | ${siteMeta.title}`;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.href;
const navigation = [
  { href: withBase(), label: "Ana Sayfa" },
  { href: withBase("arsiv/"), label: "Arşiv" },
  { href: withBase("rss.xml"), label: "RSS" },
];

function isActive(href) {
  return Astro.url.pathname === new URL(href, Astro.url).pathname;
}
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e0e0e" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NY9DPCWF93"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-NY9DPCWF93");
    </script>
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Bülten",
        url: "https://bulten.burakkutbay.dev/",
        description:
          "Burak Kutbay'ın hazırladığı AI destekli günlük teknoloji bülteni. Java, Spring, JVM, AI agent ekosistemi ve teknoloji trendlerini günlük olarak derler.",
        publisher: {
          "@type": "Person",
          name: "Burak Kutbay",
          url: "https://burakkutbay.dev/",
        },
        author: {
          "@type": "Person",
          name: "Burak Kutbay",
          url: "https://burakkutbay.dev/",
        },
        inLanguage: "tr-TR",
        potentialAction: {
          "@type": "SearchAction",
          target: "https://bulten.burakkutbay.dev/arsiv?q={search_term_string}",
          "query-input": "required name=search_term_string",
        },
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        name: "Bülten",
        url: "https://bulten.burakkutbay.dev/",
        description:
          "Burak Kutbay'ın hazırladığı günlük teknoloji ve AI bülten arşivi.",
        isPartOf: {
          "@type": "WebSite",
          name: "Bülten",
          url: "https://bulten.burakkutbay.dev/",
        },
        author: { "@type": "Person", name: "Burak Kutbay" },
        about: [
          { "@type": "Thing", name: "Java" },
          { "@type": "Thing", name: "Spring" },
          { "@type": "Thing", name: "JVM" },
          { "@type": "Thing", name: "Artificial Intelligence" },
          { "@type": "Thing", name: "AI Agents" },
          { "@type": "Thing", name: "Technology Trends" },
        ],
        inLanguage: "tr-TR",
      })}
    />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="site-header__inner container">
          <a class="brand" href={withBase()}>
            <span class="brand__symbol">&gt;_</span>
            <span class="brand__text">{siteMeta.title}</span>
          </a>
          <nav class="nav">
            {
              navigation.map((item) => (
                <a
                  class:list={[
                    "nav__link",
                    { "nav__link--active": isActive(item.href) },
                  ]}
                  href={item.href}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </header>

      <main class="container main-content">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner container">
          <div class="footer-left">
            <span class="footer-brand">&gt;_ {siteMeta.title}</span>
            <p>
              AI Agent'lerin her gün derleyip düzenlediği günlük bültenler.
              <a href="https://github.com/brkse/bulten">GitHub</a> üzerinde açık kaynak.
            </p>
          </div>
          <div class="footer-right">
            <span class="footer-stamp">SYS.OUT // BURAK KUTBAY</span>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0e0e0e;
    --surface-lowest: #000000;
    --surface-low: #131313;
    --surface: #191919;
    --surface-high: #1f1f1f;
    --surface-highest: #262626;
    --primary: #9fff88;
    --primary-dim: #01ed00;
    --secondary: #eaea00;
    --secondary-dim: #dbdb00;
    --error: #ff7351;
    --text: #ffffff;
    --text-secondary: #ababab;
    --outline: #757575;
    --outline-variant: #484848;
    --line: rgba(255, 255, 255, 0.1);
    --line-strong: rgba(255, 255, 255, 0.18);
  }

  * {
    box-sizing: border-box;
  }

  ::selection {
    background: var(--primary);
    color: var(--bg);
  }

  html {
    scroll-behavior: smooth;
    background: var(--bg);
    min-height: 100%;
  }

  body {
    margin: 0;
    color: var(--text-secondary);
    font-family:
      "Inter",
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    background: var(--bg);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  code,
  pre {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .page-shell {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .container {
    width: min(1200px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  /* ── HEADER ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(14, 14, 14, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .site-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 200ms ease;
  }

  .brand:hover {
    opacity: 0.8;
  }

  .brand__symbol {
    color: var(--primary);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .brand__text {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-style: italic;
    font-size: 1.15rem;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .nav {
    display: flex;
    gap: 0.25rem;
  }

  .nav__link {
    padding: 0.5rem 0.9rem;
    color: var(--text-secondary);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    border: 1px solid transparent;
    transition:
      color 200ms ease,
      border-color 200ms ease;
  }

  .nav__link:hover {
    color: var(--primary);
  }

  .nav__link--active {
    color: var(--primary);
    border-bottom: 2px solid var(--primary);
  }

  /* ── MAIN ── */
  .main-content {
    padding: 5rem 0 4rem;
    flex: 1;
  }

  /* ── PANEL ── */
  .panel {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 0;
    transition: border-color 250ms ease;
  }

  /* ── EYEBROW ── */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--primary);
  }

  .eyebrow::before {
    content: "//";
    color: var(--outline);
  }

  /* ── BUTTONS ── */
  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.2rem;
    border-radius: 0;
    border: 1px solid var(--outline-variant);
    color: var(--text-secondary);
    background: var(--surface);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      color 200ms ease,
      border-color 200ms ease,
      background 200ms ease;
  }

  .button:hover {
    color: var(--bg);
    background: var(--primary);
    border-color: var(--primary);
  }

  .button--primary {
    color: var(--bg);
    background: var(--primary);
    border-color: var(--primary);
    font-weight: 700;
  }

  .button--primary:hover {
    background: var(--primary-dim);
    border-color: var(--primary-dim);
  }

  /* ── META ── */
  .meta-row,
  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .meta-pill,
  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    border-radius: 0;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    color: var(--text-secondary);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── SECTION TITLE ── */
  .section-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--outline-variant);
  }

  .section-title h2 {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.3rem, 2vw, 1.8rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text);
  }

  .section-title p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  /* ── GRIDS ── */
  .grid-two {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .grid-three {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  /* ── FOOTER ── */
  .site-footer {
    background: var(--surface-low);
    border-top: 1px solid var(--outline-variant);
    padding: 2.5rem 0;
    margin-top: auto;
  }

  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
  }

  .footer-brand {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }

  .footer-left p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .footer-left a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 0.2em;
    transition: color 200ms ease;
  }

  .footer-left a:hover {
    color: var(--secondary);
  }

  .footer-stamp {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--outline);
  }

  .footer-right {
    text-align: right;
  }

  /* ── PROSE ── */
  .prose {
    font-family: "Inter", sans-serif;
    font-size: clamp(1rem, 1rem + 0.15vw, 1.12rem);
    line-height: 1.85;
    color: var(--text-secondary);
  }

  .prose :is(h1, h2, h3, h4) {
    font-family: "Space Grotesk", sans-serif;
    color: var(--text);
    line-height: 1.15;
    letter-spacing: -0.01em;
    scroll-margin-top: 6rem;
  }

  .prose h1 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .prose h2 {
    font-size: clamp(1.5rem, 2vw, 1.9rem);
    margin-top: 2.8rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--outline-variant);
  }

  .prose h3 {
    font-size: 1.25rem;
    margin-top: 2rem;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin: 1.1rem 0;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.2rem;
  }

  .prose li + li {
    margin-top: 0.5rem;
  }

  .prose li::marker {
    color: var(--primary);
  }

  .prose a {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-color: rgba(159, 255, 136, 0.3);
    text-underline-offset: 0.18em;
    transition: text-decoration-color 200ms ease;
  }

  .prose a:hover {
    text-decoration-color: var(--primary);
  }

  .prose blockquote {
    margin-left: 0;
    padding: 1rem 1.2rem;
    border-left: 4px solid var(--primary);
    border-radius: 0;
    background: rgba(159, 255, 136, 0.04);
    color: var(--text-secondary);
  }

  .prose code {
    font-size: 0.88rem;
    padding: 0.12rem 0.4rem;
    border-radius: 0;
    background: var(--surface-high);
    border: 1px solid var(--outline-variant);
    color: var(--primary);
  }

  .prose pre {
    padding: 1.2rem 1.3rem;
    border-radius: 0;
    overflow-x: auto;
    background: var(--surface-lowest);
    border: 1px solid var(--outline-variant);
    color: #e4e4e7;
  }

  .prose pre code {
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
  }

  .prose strong {
    color: var(--text);
    font-weight: 600;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--outline-variant);
    margin: 2.5rem 0;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 920px) {
    .grid-two,
    .grid-three {
      grid-template-columns: 1fr;
    }

    .site-footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-right {
      text-align: left;
    }
  }

  @media (max-width: 720px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .container {
      width: min(100vw - 1rem, 1200px);
    }

    .main-content {
      padding-top: 4.5rem;
    }
  }
</style>
