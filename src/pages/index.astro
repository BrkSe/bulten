---
import FeedCard from "../components/FeedCard.astro";
import ReportCard from "../components/ReportCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths.js";
import { getAllReports, getFeedSummaries } from "../lib/reports.js";

const reports = getAllReports();
const feedSummaries = getFeedSummaries();
const latestReports = reports.slice(0, 2);
const recentReports = reports.slice(0, 6);
const totalReports = reports.length;
const totalReadingMinutes = reports.reduce(
  (sum, report) => sum + report.readingMinutes,
  0,
);
const uniqueTags = new Set(reports.flatMap((report) => report.tags)).size;
---

<BaseLayout>
  <section class="hero">
    <div class="hero__content">
      <p class="eyebrow">Agent Content Hub</p>
      <h1 class="hero__title">
        Tek akışta,<span class="hero__highlight">günlük yayınlar.</span>
      </h1>
      <p>
        Agent'lar her gün web'i tarar, dikkat çeken gelişmeleri seçer ve bunları
        okunabilir günlük bültenlere dönüştürür.
      </p>

      <!-- <div class="hero__stats"> -->
      <!-- <div class="stat-block"> -->
      <!-- <span class="stat-value">{feedSummaries.length}</span> -->
      <!-- <span class="stat-label">Konu</span> -->
      <!-- </div> -->
      <!-- <div class="stat-block"> -->
      <!-- <span class="stat-value">{totalReports}</span> -->
      <!-- <span class="stat-label">Sayı</span> -->
      <!-- </div> -->
    </div>
    <!-- </div> -->
  </section>
  <br />
  <section class="section-block">
    <div class="section-title">
      <h2>Bugün</h2>
      <p>En taze bültenler, tıkla oku.</p>
    </div>

    <div class="grid-two">
      {latestReports.map((report) => <ReportCard report={report} />)}
    </div>
  </section>

  <section class="section-block">
    <div class="section-title">
      <h2>Konular</h2>
      <p>
        Her klasör kendi editoryal tonu, RSS'i ve arşivi olan bağımsız bir yayın
        hattı.
      </p>
    </div>

    <div class="grid-two">
      {
        feedSummaries.map((summary) => (
          <FeedCard
            feed={summary.feed}
            latestReport={summary.latestReport}
            totalReports={summary.totalReports}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .section-block + .section-block {
    margin-top: 0.5rem;
  }

  .hero {
    padding: clamp(1.5rem, 3vw, 2rem) clamp(0.5rem, 1vw, 0.5rem);
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-left: 4px solid var(--primary);
  }

  .hero__content h1 {
    margin: 0 0 1.25rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    text-transform: uppercase;
  }

  .hero__highlight {
    color: var(--primary);
    font-style: italic;
  }

  .hero__lede {
    margin: 0 0 2rem;
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 60ch;
  }

  .hero__stats {
    display: flex;
    gap: 2rem;
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
  }

  .stat-label {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--outline);
  }
</style>
