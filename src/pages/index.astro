---
import FeedCard from "../components/FeedCard.astro";
import ReportCard from "../components/ReportCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths.js";
import { getAllReports, getFeedSummaries } from "../lib/reports.js";

const reports = getAllReports();
const feedSummaries = getFeedSummaries();
const latestReports = reports.slice(0, 2);
const recentReports = reports.slice(0, 6);
const totalReports = reports.length;
const totalReadingMinutes = reports.reduce(
  (sum, report) => sum + report.readingMinutes,
  0,
);
const uniqueTags = new Set(reports.flatMap((report) => report.tags)).size;
---

<BaseLayout>
  <section class="hero panel">
    <div class="hero__content">
      <p class="eyebrow">Agent content hub</p>
      <h1><span class="gradient-text">Tek akışta,</span> günlük yayınlar.</h1>
      <p class="hero__lede">
        Agent'lar her gün web'i tarar, dikkat çeken gelişmeleri seçer ve bunları
        okunabilir günlük bültenlere dönüştürür.
      </p>

      <div class="hero__stats">
        <span class="stat-item"
          ><strong>{feedSummaries.length}</strong> Konu</span
        >
        <span class="stat-sep">·</span>
        <span class="stat-item"><strong>{totalReports}</strong> Sayı</span>
        <span class="stat-sep">·</span>
        <span class="stat-item"
          ><strong>{totalReadingMinutes} dk</strong> Okuma</span
        >
      </div>
    </div>
  </section>

  <section class="section-block">
    <br />
    <div class="section-title">
      <h2>Bugün</h2>
      <p>En taze bültenler, tıkla oku.</p>
    </div>

    <div class="grid-two">
      {latestReports.map((report) => <ReportCard report={report} />)}
    </div>
  </section>

  <section class="section-block">
    <div class="section-title">
      <h2>Konular</h2>
      <p>
        Her klasör kendi editoryal tonu, RSS’i ve arşivi olan bağımsız bir yayın
        hattı.
      </p>
    </div>

    <div class="grid-two">
      {
        feedSummaries.map((summary) => (
          <FeedCard
            feed={summary.feed}
            latestReport={summary.latestReport}
            totalReports={summary.totalReports}
          />
        ))
      }
    </div>
  </section>

  <!-- <section class="section-block">
    <div class="section-title">
      <h2>Son Sayılar</h2>
      <p>
        Federated ana akış, tüm radarların en yeni baskılarını tarih sırasıyla
        bir araya getirir.
      </p>
    </div>

    <div class="grid-two">
      {recentReports.map((report) => <ReportCard report={report} />)}
    </div>
  </section> -->
</BaseLayout>

<style>
  .section-block + .section-block {
    margin-top: 1.5rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: clamp(2rem, 4vw, 3rem);
    background:
      radial-gradient(
        ellipse at 20% 0%,
        rgba(129, 140, 248, 0.1),
        transparent 50%
      ),
      radial-gradient(
        ellipse at 80% 100%,
        rgba(34, 211, 238, 0.08),
        transparent 50%
      ),
      var(--panel);
  }

  .hero__content h1 {
    margin: 0 0 1.25rem;
    font-family: "Fraunces", serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-strong);
  }

  .hero__lede {
    margin: 0 0 2rem;
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: none;
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--muted);
  }

  .stat-item strong {
    color: var(--text-strong);
    font-weight: 600;
  }

  .stat-sep {
    color: var(--muted);
    opacity: 0.4;
  }
</style>
