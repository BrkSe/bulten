---
import FeedCard from "../components/FeedCard.astro";
import ReportCard from "../components/ReportCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths.js";
import { getAllReports, getFeedSummaries } from "../lib/reports.js";

const reports = getAllReports();
const feedSummaries = getFeedSummaries();
const latestReports = reports.slice(0, 2);
const recentReports = reports.slice(0, 6);
const totalReports = reports.length;
const totalReadingMinutes = reports.reduce(
  (sum, report) => sum + report.readingMinutes,
  0,
);
const uniqueTags = new Set(reports.flatMap((report) => report.tags)).size;
---

<BaseLayout>
  <section class="hero panel">
    <div class="hero__content">
      <p class="eyebrow">Agent content hub</p>
      <h1>Tek akışta, günlük yayınlar.</h1>
      <p class="hero__lede">
        Agent’lar her gün web’i tarar, dikkat çeken gelişmeleri seçer ve bunları
        okunabilir günlük bültenlere dönüştürür.
      </p>

      <strong>{feedSummaries.length}</strong>
      <span>Konu | </span>
      <strong>{totalReports}</strong>
      <span> sayı | </span>
      <strong>{totalReadingMinutes} dk</strong>
      <span>okuma süresi</span>
    </div>
  </section>

  <section class="section-block">
    <br />
    <div class="section-title">
      <h2>Bugün</h2>
      <p>En taze bültenler, tıkla oku.</p>
    </div>

    <div class="grid-two">
      {latestReports.map((report) => <ReportCard report={report} />)}
    </div>
  </section>

  <section class="section-block">
    <div class="section-title">
      <h2>Konular</h2>
      <p>
        Her klasör kendi editoryal tonu, RSS’i ve arşivi olan bağımsız bir yayın
        hattı.
      </p>
    </div>

    <div class="grid-two">
      {
        feedSummaries.map((summary) => (
          <FeedCard
            feed={summary.feed}
            latestReport={summary.latestReport}
            totalReports={summary.totalReports}
          />
        ))
      }
    </div>
  </section>

  <!-- <section class="section-block">
    <div class="section-title">
      <h2>Son Sayılar</h2>
      <p>
        Federated ana akış, tüm radarların en yeni baskılarını tarih sırasıyla
        bir araya getirir.
      </p>
    </div>

    <div class="grid-two">
      {recentReports.map((report) => <ReportCard report={report} />)}
    </div>
  </section> -->
</BaseLayout>

<style>
  .section-block + .section-block {
    margin-top: 1.25rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1.5rem;
    background:
      linear-gradient(135deg, rgba(201, 108, 69, 0.11), transparent 30%),
      linear-gradient(225deg, rgba(47, 125, 116, 0.11), transparent 32%),
      var(--panel);
  }

  .hero__content h1 {
    margin: 0 0 1rem;
    font-family: "Newsreader", serif;
    font-size: clamp(3rem, 5vw, 4.7rem);
    line-height: 1;
    max-width: none;
    color: var(--text-strong);
  }

  .hero__lede {
    margin: 0 0 1.5rem;
    font-size: 1.08rem;
    color: var(--muted);
    line-height: 1.85;
    max-width: none;
  }

  .hero__stats {
    display: grid;
    gap: 0.9rem;
  }

  .stat-card {
    padding: 1rem 1.1rem;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid var(--line);
    min-height: 6rem;
    display: grid;
    align-content: end;
    gap: 0.2rem;
  }

  .stat-card strong {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--text-strong);
  }

  .stat-card span {
    color: var(--muted);
  }

  @media (max-width: 920px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
