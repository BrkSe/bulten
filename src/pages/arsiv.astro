---
import BaseLayout from "../layouts/BaseLayout.astro";
import ReportCard from "../components/ReportCard.astro";
import { getAllReports, formatMonthLabel } from "../lib/reports.js";

const reports = getAllReports();

const feedFilters = Array.from(
  reports.reduce((map, report) => {
    const existing = map.get(report.feed.id);

    if (existing) {
      existing.count += 1;
      return map;
    }

    map.set(report.feed.id, {
      id: report.feed.id,
      label: report.feed.shortTitle,
      accent: report.feed.accent,
      count: 1,
    });

    return map;
  }, new Map()),
  ([, value]) => value,
);

const tagFilters = Array.from(
  reports.reduce((map, report) => {
    report.tags.forEach((tag) => {
      map.set(tag, (map.get(tag) ?? 0) + 1);
    });

    return map;
  }, new Map()),
  ([label, count]) => ({ label, count }),
)
  .sort(
    (left, right) =>
      right.count - left.count || left.label.localeCompare(right.label, "tr"),
  )
  .slice(0, 14);

const groups = Array.from(
  reports.reduce((map, report) => {
    const label = formatMonthLabel(report.date);

    if (!map.has(label)) {
      map.set(label, []);
    }

    map.get(label).push(report);
    return map;
  }, new Map()),
);
---

<BaseLayout title="Arşiv">
  <div class="archive-stack">
    <section class="archive-hero">
      <p class="eyebrow">Tam arşiv</p>
      <h1>Tüm radar sayıları tek bakışta.</h1>
      <p>
        Akış bağımsızlığını korurken, bütün sayılar tek bir kronolojik yayında
        toplanıyor.
      </p>
    </section>

    <section class="archive-toolbar" data-filter-root>
      <div class="archive-toolbar__top">
        <div>
          <p class="eyebrow">Hızlı filtre</p>
          <h2>Aradığın sayıyı saniyeler içinde bul.</h2>
        </div>

        <div class="archive-toolbar__summary">
          <strong data-results-count>{reports.length}</strong>
          <span>sonuç</span>
          <button class="button" type="button" data-reset>Temizle</button>
        </div>
      </div>

      <label class="filter-search">
        <span>Başlık, özet veya etiket ara</span>
        <input
          type="search"
          name="q"
          placeholder="Örn. AI agent, Spring Boot, veri katmanı..."
          autocomplete="off"
          data-search
        />
      </label>

      <div class="filter-block">
        <div class="filter-block__label">Kaynak</div>
        <div
          class="filter-chip-row"
          role="group"
          aria-label="Kaynak filtreleri"
        >
          <button
            class="filter-chip is-active"
            type="button"
            data-feed-filter=""
            data-filter-label="Tümü"
          >
            <span>Tümü</span>
            <small>{reports.length}</small>
          </button>

          {
            feedFilters.map((feed) => (
              <button
                class="filter-chip"
                type="button"
                style={`--filter-accent: ${feed.accent};`}
                data-feed-filter={feed.id}
                data-filter-label={feed.label}
              >
                <span>{feed.label}</span>
                <small>{feed.count}</small>
              </button>
            ))
          }
        </div>
      </div>

      <p class="active-filters" data-active-filters hidden></p>
    </section>

    <section class="archive-empty" data-empty-state hidden>
      <p class="eyebrow">Sonuç yok</p>
      <h3>Bu filtrelerle eşleşen sayı bulunamadı.</h3>
      <p>Aramayı sadeleştirip başka bir kaynak veya etiket deneyebilirsin.</p>
    </section>

    <div class="archive-groups">
      {
        groups.map(([label, monthReports]) => (
          <section class="archive-group" data-month-group>
            <div class="section-title">
              <h2>{label}</h2>
              <p>
                <span data-group-count>{monthReports.length}</span> sayı
              </p>
            </div>

            <div class="grid-two">
              {monthReports.map((report) => (
                <div
                  class="archive-card"
                  data-report-card
                  data-feed={report.feed.id}
                  data-tags={report.tags
                    .map((tag) => tag.toLocaleLowerCase("tr-TR"))
                    .join("|")}
                  data-search={[
                    report.title,
                    report.excerpt,
                    report.feed.shortTitle,
                    ...report.tags,
                  ]
                    .join(" ")
                    .toLocaleLowerCase("tr-TR")}
                >
                  <ReportCard report={report} />
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .archive-stack {
    display: grid;
    gap: 1.25rem;
  }

  .archive-hero {
    padding: clamp(1.8rem, 3.5vw, 2.5rem);
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-left: 4px solid var(--primary);
  }

  .archive-hero h1 {
    margin: 0 0 0.8rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: var(--text);
  }

  .archive-hero p:last-child {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 58ch;
  }

  .archive-groups {
    display: grid;
    gap: 1.35rem;
  }

  .archive-toolbar {
    padding: clamp(1.2rem, 2.8vw, 1.7rem);
    display: grid;
    gap: 1.15rem;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
  }

  .archive-toolbar__top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .archive-toolbar__top h2 {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    font-weight: 700;
    color: var(--text);
  }

  .archive-toolbar__summary {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--text-secondary);
    flex-wrap: wrap;
  }

  .archive-toolbar__summary strong {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.6rem, 2vw, 2rem);
    line-height: 1;
    color: var(--primary);
  }

  .filter-search {
    display: grid;
    gap: 0.5rem;
  }

  .filter-search span {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .filter-search input {
    width: 100%;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--outline-variant);
    background: var(--surface);
    color: var(--text);
    font: inherit;
    font-size: 0.95rem;
    transition: border-color 200ms ease;
  }

  .filter-search input::placeholder {
    color: var(--outline);
  }

  .filter-search input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(159, 255, 136, 0.15);
  }

  .filter-block {
    display: grid;
    gap: 0.7rem;
  }

  .filter-block__label {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--outline);
  }

  .filter-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--outline-variant);
    background: var(--surface);
    color: var(--text-secondary);
    font: inherit;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: border-color 200ms ease, background 200ms ease, color 200ms ease;
  }

  .filter-chip:hover {
    border-color: var(--outline);
    color: var(--text);
  }

  .filter-chip.is-active {
    color: var(--bg);
    border-color: var(--primary);
    background: var(--primary);
  }

  .filter-chip small {
    color: inherit;
    opacity: 0.7;
    font-size: 0.7rem;
  }

  .active-filters {
    margin: 0;
    padding-top: 0.15rem;
    color: var(--text-secondary);
    font-size: 0.88rem;
  }

  .archive-empty {
    padding: 2rem;
    text-align: center;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
  }

  .archive-empty h3 {
    margin: 0 0 0.65rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
  }

  .archive-empty p:last-child {
    margin: 0;
    color: var(--text-secondary);
  }

  .archive-card[hidden],
  .archive-group[hidden],
  .archive-empty[hidden] {
    display: none !important;
  }

  @media (max-width: 720px) {
    .archive-toolbar__summary {
      align-items: center;
    }
  }
</style>

<script is:inline>
  const filterRoot = document.querySelector("[data-filter-root]");

  if (filterRoot) {
    const searchInput = filterRoot.querySelector("[data-search]");
    const resetButton = filterRoot.querySelector("[data-reset]");
    const resultCount = filterRoot.querySelector("[data-results-count]");
    const activeFilters = filterRoot.querySelector("[data-active-filters]");
    const emptyState = document.querySelector("[data-empty-state]");
    const cards = Array.from(document.querySelectorAll("[data-report-card]"));
    const groups = Array.from(document.querySelectorAll("[data-month-group]"));
    const feedButtons = Array.from(
      filterRoot.querySelectorAll("[data-feed-filter]"),
    );
    const tagButtons = Array.from(
      filterRoot.querySelectorAll("[data-tag-filter]"),
    );

    const state = {
      search: "",
      feed: "",
      tag: "",
    };

    const normalize = (value) => value.toLocaleLowerCase("tr-TR").trim();

    function setActive(buttons, key, currentValue) {
      buttons.forEach((button) => {
        button.classList.toggle(
          "is-active",
          (button.dataset[key] || "") === currentValue,
        );
      });
    }

    function getButtonLabel(buttons, key, currentValue) {
      return (
        buttons.find((button) => (button.dataset[key] || "") === currentValue)
          ?.dataset.filterLabel || ""
      );
    }

    function syncGroupCounts() {
      groups.forEach((group) => {
        const visibleCards = group.querySelectorAll(
          "[data-report-card]:not([hidden])",
        ).length;
        const countNode = group.querySelector("[data-group-count]");

        if (countNode) {
          countNode.textContent = String(visibleCards);
        }

        group.hidden = visibleCards === 0;
      });
    }

    function syncSummary(visibleCount) {
      const summary = [];

      if (state.feed) {
        summary.push(
          `Kaynak: ${getButtonLabel(feedButtons, "feedFilter", state.feed)}`,
        );
      }

      if (state.tag) {
        summary.push(
          `Etiket: ${getButtonLabel(tagButtons, "tagFilter", state.tag)}`,
        );
      }

      if (state.search) {
        summary.push(`Arama: "${searchInput.value.trim()}"`);
      }

      activeFilters.hidden = summary.length === 0;
      activeFilters.textContent = summary.join(" \u2022 ");
      emptyState.hidden = visibleCount !== 0;
    }

    function applyFilters() {
      let visibleCount = 0;

      cards.forEach((card) => {
        const matchesFeed = !state.feed || card.dataset.feed === state.feed;
        const tags = card.dataset.tags ? card.dataset.tags.split("|") : [];
        const matchesTag = !state.tag || tags.includes(state.tag);
        const matchesSearch =
          !state.search || (card.dataset.search || "").includes(state.search);
        const isVisible = matchesFeed && matchesTag && matchesSearch;

        card.hidden = !isVisible;

        if (isVisible) {
          visibleCount += 1;
        }
      });

      syncGroupCounts();
      syncSummary(visibleCount);
      resultCount.textContent = String(visibleCount);
    }

    function resetFilters() {
      state.search = "";
      state.feed = "";
      state.tag = "";
      searchInput.value = "";
      setActive(feedButtons, "feedFilter", "");
      setActive(tagButtons, "tagFilter", "");
      applyFilters();
    }

    searchInput?.addEventListener("input", (event) => {
      state.search = normalize(event.currentTarget.value);
      applyFilters();
    });

    feedButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextValue = button.dataset.feedFilter || "";
        state.feed = state.feed === nextValue ? "" : nextValue;
        setActive(feedButtons, "feedFilter", state.feed);
        applyFilters();
      });
    });

    tagButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextValue = normalize(button.dataset.tagFilter || "");
        state.tag = state.tag === nextValue ? "" : nextValue;
        setActive(tagButtons, "tagFilter", state.tag);

        if (!state.tag) {
          setActive(tagButtons, "tagFilter", "");
        }

        applyFilters();
      });
    });

    resetButton?.addEventListener("click", resetFilters);
    applyFilters();
  }
</script>
