---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReportCard from "../../../components/ReportCard.astro";
import { withBase } from "../../../lib/paths.js";
import { getFeeds, getReportsByFeedId } from "../../../lib/reports.js";

export function getStaticPaths() {
  return getFeeds().map((feed) => ({
    params: { feed: feed.id },
    props: {
      feed,
      reports: getReportsByFeedId(feed.id),
    },
  }));
}

const { feed, reports } = Astro.props;
const latestReport = reports[0] ?? null;
---

<BaseLayout title={feed.shortTitle} description={feed.description}>
  <section class="source-hero" style={`--source-accent: ${feed.accent};`}>
    <div class="source-hero__copy">
      <p class="eyebrow">{feed.badge}</p>
      <h1>{feed.title}</h1>
      <p>{feed.strap}</p>

      <div class="meta-row">
        <span class="meta-pill">{reports.length} sayı</span>
      </div>
    </div>

    <div class="source-hero__actions">
      <a
        class="button button--primary"
        href={latestReport ? withBase(latestReport.route) : withBase()}
      >
        {latestReport ? "En yeni sayıyı aç" : "Ana sayfa"}
      </a>
    </div>
  </section>

  {
    latestReport && (
      <section class="section-block">
        <div class="section-title">
          <h2>Öne çıkan sayı</h2>
          <p>Bu akışın en son yayınlanan baskısı.</p>
        </div>

        <ReportCard report={latestReport} showFeed={false} />
      </section>
    )
  }

  <section class="section-block">
    <div class="section-title">
      <h2>Akış arşivi</h2>
      <p>Tüm sayılar tarih sırasıyla burada tutulur.</p>
    </div>

    <div class="grid-two">
      {reports.map((report) => <ReportCard report={report} showFeed={false} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .section-block + .section-block {
    margin-top: 1.5rem;
  }

  .source-hero {
    padding: clamp(1.8rem, 3.5vw, 2.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-left: 4px solid var(--source-accent);
    margin-bottom: 1.5rem;
  }

  .source-hero h1 {
    margin: 0 0 0.8rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 1.1;
    font-weight: 700;
    color: var(--text);
  }

  .source-hero p:last-of-type {
    margin: 0 0 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 0.92rem;
  }

  .source-hero__actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    justify-content: flex-end;
  }

  @media (max-width: 900px) {
    .source-hero {
      grid-template-columns: 1fr;
    }

    .source-hero__actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
