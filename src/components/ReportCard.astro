---
import { withBase } from "../lib/paths.js";
import { formatDateLong } from "../lib/reports.js";

const { report, showFeed = true } = Astro.props;
---

<article
  class="report-card"
  style={`--report-accent: ${report.feed.accent};`}
>
  <div class="report-card__meta">
    <span class="meta-pill meta-pill--issue">Sayı {report.issueNumber}</span>
    <span class="meta-pill">{formatDateLong(report.date)}</span>
    {
      showFeed && (
        <a
          class="meta-pill report-card__feed-link"
          href={withBase(report.feedRoute)}
        >
          {report.feed.shortTitle}
        </a>
      )
    }
    <span class="meta-pill">{report.readingMinutes} dk</span>
  </div>

  <h3>
    <a href={withBase(report.route)}>{report.title}</a>
  </h3>

  <p>{report.excerpt}</p>
</article>

<style>
  .report-card {
    padding: 1.5rem;
    display: grid;
    gap: 0.85rem;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-left: 4px solid transparent;
    transition: border-color 200ms ease, background 200ms ease;
  }

  .report-card:hover {
    border-left-color: var(--report-accent);
    background: var(--surface);
  }

  .report-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .report-card__feed-link {
    transition: color 200ms ease;
  }

  .report-card__feed-link:hover {
    color: var(--primary);
  }

  .report-card h3 {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .report-card h3 a {
    transition: color 200ms ease;
  }

  .report-card h3 a:hover {
    color: var(--primary);
  }

  .report-card p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .meta-pill--issue {
    color: var(--bg);
    border-color: transparent;
    background: var(--report-accent);
    font-weight: 700;
    font-size: 0.72rem;
  }
</style>
