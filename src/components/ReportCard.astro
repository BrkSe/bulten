---
import { withBase } from "../lib/paths.js";
import { formatDateLong } from "../lib/reports.js";

const { report, showFeed = true } = Astro.props;
---

<article
  class="report-card panel"
  style={`--report-accent: ${report.feed.accent};`}
>
  <div class="report-card__meta">
    <span class="meta-pill meta-pill--issue">Sayı {report.issueNumber}</span>
    <span class="meta-pill">{formatDateLong(report.date)}</span>
    {
      showFeed && (
        <a
          class="meta-pill report-card__feed-link"
          href={withBase(report.feedRoute)}
        >
          {report.feed.shortTitle}
        </a>
      )
    }
    <span class="meta-pill">{report.readingMinutes} dk</span>
  </div>

  <h3>
    <a href={withBase(report.route)}>{report.title}</a>
  </h3>

  <p>{report.excerpt}</p>

  <!-- {report.tags.length > 0 && (
    <div class="pill-row">
      {report.tags.slice(0, 4).map((tag) => (
        <span class="tag-pill">{tag}</span>
      ))}
    </div>
  )} -->
</article>

<style>
  .report-card {
    padding: 1.5rem;
    display: grid;
    gap: 1rem;
    border-color: rgba(255, 255, 255, 0.06);
    background:
      radial-gradient(
        ellipse at top right,
        color-mix(in srgb, var(--report-accent) 6%, transparent),
        transparent 60%
      ),
      var(--panel);
    transition:
      border-color 250ms ease,
      transform 250ms ease,
      box-shadow 250ms ease;
  }

  .report-card:hover {
    border-color: color-mix(
      in srgb,
      var(--report-accent) 25%,
      rgba(255, 255, 255, 0.12)
    );
    transform: translateY(-2px);
    box-shadow:
      0 0 40px color-mix(in srgb, var(--report-accent) 8%, transparent),
      var(--shadow);
  }

  .report-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .report-card__feed-link {
    transition: color 200ms ease;
  }

  .report-card__feed-link:hover {
    color: var(--text-strong);
  }

  .meta-pill--issue {
    color: #fff;
    border-color: transparent;
    background: color-mix(
      in srgb,
      var(--report-accent) 80%,
      rgba(0, 0, 0, 0.2)
    );
    font-weight: 600;
    font-size: 0.75rem;
  }

  .report-card h3 {
    margin: 0;
    font-size: clamp(1.3rem, 2vw, 1.65rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--text-strong);
  }

  .report-card h3 a {
    transition: color 200ms ease;
  }

  .report-card h3 a:hover {
    color: var(--accent-1);
  }

  .report-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
    font-size: 0.92rem;
  }
</style>
