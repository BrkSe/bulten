---
const { headings = [] } = Astro.props;
---

{
  headings.length > 0 && (
    <aside class="toc">
      <p class="eyebrow">İçindekiler</p>
      <ul>
        {headings.map((heading) => (
          <li class:list={[`depth-${heading.depth}`]}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

<style>
  .toc {
    position: sticky;
    top: 4.5rem;
    padding: 1.25rem;
    align-self: start;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-left: 4px solid var(--primary);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .toc li {
    line-height: 1.4;
    font-size: 0.85rem;
  }

  .toc li.depth-3 {
    padding-left: 0.85rem;
    font-size: 0.8rem;
  }

  .toc a {
    color: var(--text-secondary);
    transition: color 200ms ease;
  }

  .toc a:hover {
    color: var(--primary);
  }
</style>
