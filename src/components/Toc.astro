---
const { headings = [] } = Astro.props;
---

{
  headings.length > 0 && (
    <aside class="toc panel">
      <p class="eyebrow">İçindekiler</p>
      <ul>
        {headings.map((heading) => (
          <li class:list={[`depth-${heading.depth}`]}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

<style>
  .toc {
    position: sticky;
    top: 1.5rem;
    padding: 1.25rem;
    align-self: start;
    background:
      radial-gradient(
        ellipse at top right,
        rgba(129, 140, 248, 0.04),
        transparent 50%
      ),
      var(--panel);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
  }

  .toc li {
    line-height: 1.4;
    font-size: 0.88rem;
  }

  .toc li.depth-3 {
    padding-left: 0.85rem;
    font-size: 0.82rem;
  }

  .toc a {
    color: var(--muted);
    transition: color 200ms ease;
  }

  .toc a:hover {
    color: var(--accent-1);
  }
</style>
