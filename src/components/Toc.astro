---
const { headings = [] } = Astro.props;
---

{
  headings.length > 0 && (
    <aside class="toc panel">
      <p class="eyebrow">İçindekiler</p>
      <ul>
        {headings.map((heading) => (
          <li class:list={[`depth-${heading.depth}`]}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

<style>
  .toc {
    padding: 1.25rem;
    align-self: start;
  }

  @media (min-width: 981px) {
    .toc {
      position: sticky;
      top: clamp(5.5rem, 12vh, 8.5rem);
      max-height: calc(100vh - clamp(5.5rem, 12vh, 8.5rem) - 1rem);
      overflow: auto;
      overscroll-behavior: contain;
      scrollbar-width: thin;
    }
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .toc li {
    line-height: 1.45;
  }

  .toc li.depth-3 {
    padding-left: 0.85rem;
    color: var(--muted);
  }

  .toc a {
    color: inherit;
  }

  .toc a:hover {
    color: var(--text);
  }
</style>
