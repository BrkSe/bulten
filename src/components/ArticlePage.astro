---
import BaseLayout from "../layouts/BaseLayout.astro";
import Toc from "./Toc.astro";
import { withBase } from "../lib/paths.js";
import { getReportsByFeedId, formatDateLong } from "../lib/reports.js";

const { report } = Astro.props;

const feedReports = getReportsByFeedId(report.feed.id);
const currentIndex = feedReports.findIndex((item) => item.slug === report.slug);
const newerReport = currentIndex > 0 ? feedReports[currentIndex - 1] : null;
const olderReport =
  currentIndex < feedReports.length - 1 ? feedReports[currentIndex + 1] : null;
---

<BaseLayout title={report.title} description={report.excerpt}>
  <section
    class="article-hero panel"
    style={`--article-accent: ${report.feed.accent};`}
  >
    <div class="article-hero__body">
      <div class="article-hero__topline">
        <a class="article-hero__source" href={withBase(report.feedRoute)}
          >{report.feed.shortTitle}</a
        >
        <span class="article-hero__issue">Sayı {report.issueNumber}</span>
      </div>
      <h1>{report.title}</h1>
      <p>{report.excerpt}</p>

      <div class="meta-row">
        <span class="meta-pill">{formatDateLong(report.date)}</span>
        <span class="meta-pill">{report.readingMinutes} dk okuma</span>
      </div>

      <!-- {
        report.tags.length > 0 && (
          <div class="pill-row">
            {report.tags.map((tag) => (
              <span class="tag-pill">{tag}</span>
            ))}
          </div>
        )
      } -->
    </div>
  </section>

  <section class="article-grid">
    <article class="panel article-panel">
      <div class="prose" set:html={report.html} />
    </article>

    <Toc headings={report.headings} />
  </section>

  <section class="article-nav panel">
    <div class="article-nav__item">
      <small>Daha yeni</small>
      {
        newerReport ? (
          <a href={withBase(newerReport.route)}>{newerReport.title}</a>
        ) : (
          <span>Bu akışın en yeni sayısı.</span>
        )
      }
    </div>

    <div class="article-nav__item article-nav__item--center">
      <small>Akış</small>
      <a href={withBase(report.feedRoute)}>{report.feed.shortTitle} arşivi</a>
    </div>

    <div class="article-nav__item article-nav__item--right">
      <small>Daha eski</small>
      {
        olderReport ? (
          <a href={withBase(olderReport.route)}>{olderReport.title}</a>
        ) : (
          <span>Bu akışın ilk sayısı.</span>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .article-hero {
    padding: clamp(1.8rem, 3.5vw, 2.5rem);
    margin-bottom: 1.2rem;
    border-color: rgba(255, 255, 255, 0.06);
    background:
      radial-gradient(
        ellipse at top right,
        color-mix(in srgb, var(--article-accent) 8%, transparent),
        transparent 55%
      ),
      radial-gradient(
        ellipse at bottom left,
        rgba(129, 140, 248, 0.04),
        transparent 50%
      ),
      var(--panel);
  }

  .article-hero__source {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.85rem;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 500;
    transition:
      color 200ms ease,
      border-color 200ms ease;
  }

  .article-hero__source:hover {
    color: var(--text-strong);
    border-color: var(--line-strong);
  }

  .article-hero__topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    margin-bottom: 0.85rem;
  }

  .article-hero__issue {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    color: #fff;
    background: color-mix(
      in srgb,
      var(--article-accent) 80%,
      rgba(0, 0, 0, 0.2)
    );
    font-weight: 600;
    font-size: 0.78rem;
  }

  .article-hero h1 {
    margin: 0 0 0.9rem;
    font-family: "Fraunces", serif;
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-strong);
  }

  .article-hero p {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.8;
    font-size: 1.02rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 1rem;
    align-items: start;
  }

  .article-panel {
    padding: clamp(1.5rem, 3vw, 2.2rem);
    background: var(--panel-strong);
  }

  .article-panel .prose {
    max-width: 68ch;
  }

  .article-nav {
    margin-top: 1.2rem;
    padding: 1.25rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .article-nav__item {
    display: grid;
    gap: 0.35rem;
  }

  .article-nav__item--center {
    text-align: center;
  }

  .article-nav__item--right {
    text-align: right;
  }

  .article-nav small {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .article-nav a {
    font-size: 0.95rem;
    color: var(--text-strong);
    transition: color 200ms ease;
  }

  .article-nav a:hover {
    color: var(--accent-1);
  }

  .article-nav span {
    color: var(--muted);
    font-size: 0.9rem;
  }

  @media (max-width: 980px) {
    .article-grid,
    .article-nav {
      grid-template-columns: 1fr;
    }

    .article-nav__item--center,
    .article-nav__item--right {
      text-align: left;
    }
  }
</style>
