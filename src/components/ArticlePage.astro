---
import BaseLayout from "../layouts/BaseLayout.astro";
import Toc from "./Toc.astro";
import { withBase } from "../lib/paths.js";
import { getReportsByFeedId, formatDateLong } from "../lib/reports.js";

const { report } = Astro.props;

const feedReports = getReportsByFeedId(report.feed.id);
const currentIndex = feedReports.findIndex((item) => item.slug === report.slug);
const newerReport = currentIndex > 0 ? feedReports[currentIndex - 1] : null;
const olderReport =
  currentIndex < feedReports.length - 1 ? feedReports[currentIndex + 1] : null;
---

<BaseLayout title={report.title} description={report.excerpt}>
  <section
    class="article-hero"
    style={`--article-accent: ${report.feed.accent};`}
  >
    <div class="article-hero__body">
      <div class="article-hero__topline">
        <a class="article-hero__source" href={withBase(report.feedRoute)}
          >{report.feed.shortTitle}</a
        >
        <span class="article-hero__issue">Sayı {report.issueNumber}</span>
      </div>
      <h1>{report.title}</h1>
      <p>{report.excerpt}</p>

      <div class="meta-row">
        <span class="meta-pill">{formatDateLong(report.date)}</span>
        <span class="meta-pill">{report.readingMinutes} dk okuma</span>
      </div>
    </div>
  </section>

  <section class="article-grid">
    <article class="article-panel">
      <div class="prose" set:html={report.html} />
    </article>

    <Toc headings={report.headings} />
  </section>

  <section class="article-nav">
    <div class="article-nav__item">
      <small>Daha yeni</small>
      {
        newerReport ? (
          <a href={withBase(newerReport.route)}>{newerReport.title}</a>
        ) : (
          <span>Bu akışın en yeni sayısı.</span>
        )
      }
    </div>

    <div class="article-nav__item article-nav__item--center">
      <small>Akış</small>
      <a href={withBase(report.feedRoute)}>{report.feed.shortTitle} arşivi</a>
    </div>

    <div class="article-nav__item article-nav__item--right">
      <small>Daha eski</small>
      {
        olderReport ? (
          <a href={withBase(olderReport.route)}>{olderReport.title}</a>
        ) : (
          <span>Bu akışın ilk sayısı.</span>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .article-hero {
    padding: clamp(1.8rem, 3.5vw, 2.5rem);
    margin-bottom: 1.2rem;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-left: 4px solid var(--article-accent);
  }

  .article-hero__source {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.65rem;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    color: var(--text-secondary);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .article-hero__source:hover {
    color: var(--primary);
    border-color: var(--primary);
  }

  .article-hero__topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    margin-bottom: 0.85rem;
  }

  .article-hero__issue {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.65rem;
    color: var(--bg);
    background: var(--article-accent);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .article-hero h1 {
    margin: 0 0 0.9rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1.1;
    font-weight: 700;
    color: var(--text);
  }

  .article-hero p {
    margin: 0 0 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 1rem;
    align-items: start;
  }

  .article-panel {
    padding: clamp(1.5rem, 3vw, 2.2rem);
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
  }

  .article-panel .prose {
    max-width: 68ch;
  }

  .article-nav {
    margin-top: 1.2rem;
    padding: 1.25rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
  }

  .article-nav__item {
    display: grid;
    gap: 0.35rem;
  }

  .article-nav__item--center {
    text-align: center;
  }

  .article-nav__item--right {
    text-align: right;
  }

  .article-nav small {
    font-family: "Space Grotesk", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--outline);
    font-size: 0.65rem;
    font-weight: 700;
  }

  .article-nav a {
    font-size: 0.92rem;
    color: var(--text);
    transition: color 200ms ease;
  }

  .article-nav a:hover {
    color: var(--primary);
  }

  .article-nav span {
    color: var(--text-secondary);
    font-size: 0.88rem;
  }

  @media (max-width: 980px) {
    .article-grid,
    .article-nav {
      grid-template-columns: 1fr;
    }

    .article-nav__item--center,
    .article-nav__item--right {
      text-align: left;
    }
  }
</style>
