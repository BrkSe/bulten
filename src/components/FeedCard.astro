---
import { withBase } from '../lib/paths.js';
import { formatDateLong } from '../lib/reports.js';

const { feed, latestReport, totalReports } = Astro.props;
---

<article class="feed-card panel" style={`--feed-accent: ${feed.accent};`}>
  <div class="feed-card__top">
    <span class="feed-card__badge">{feed.badge}</span>
    <span class="meta-pill">{totalReports} sayı</span>
  </div>

  <h3>{feed.shortTitle}</h3>
  <p>{feed.description}</p>

  <div class="feed-card__meta">
    <span>Otomasyon: {feed.automationName}</span>
    <span>Klasör: <code>{feed.directory}</code></span>
  </div>

  {latestReport && (
    <a class="feed-card__latest" href={withBase(latestReport.route)}>
      <small>En yeni sayı</small>
      <span class="feed-card__issue">Sayı {latestReport.issueNumber}</span>
      <strong>{latestReport.title}</strong>
      <span class="feed-card__date">{formatDateLong(latestReport.date)}</span>
    </a>
  )}

  <div class="button-row">
    <a class="button button--primary" href={withBase(`kaynak/${feed.id}/`)}>Akışı Aç</a>
    <a class="button" href={withBase(`kaynak/${feed.id}/rss.xml`)}>RSS</a>
  </div>
</article>

<style>
  .feed-card {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-color: color-mix(in srgb, var(--feed-accent) 28%, var(--line-strong));
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(255, 247, 236, 0.95)),
      radial-gradient(circle at top right, color-mix(in srgb, var(--feed-accent) 14%, rgba(255, 255, 255, 0.92)), transparent 38%);
    box-shadow: var(--shadow-soft);
  }

  .feed-card__top,
  .feed-card__meta {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .feed-card__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    font-size: 0.78rem;
    color: #fff7ef;
    background: color-mix(in srgb, var(--feed-accent) 88%, black 4%);
    font-weight: 700;
  }

  .feed-card h3 {
    margin: 0;
    font-size: 1.55rem;
    color: var(--text-strong);
  }

  .feed-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .feed-card__meta {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .feed-card__latest {
    display: grid;
    gap: 0.25rem;
    padding: 1rem;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid var(--line);
  }

  .feed-card__latest small {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
  }

  .feed-card__latest strong {
    font-size: 1.02rem;
    color: var(--text-strong);
  }

  .feed-card__issue {
    color: color-mix(in srgb, var(--feed-accent) 92%, black 5%);
    font-weight: 700;
    font-size: 0.92rem;
  }

  .feed-card__date {
    color: var(--muted);
    font-size: 0.9rem;
  }

  code {
    font-size: 0.84rem;
  }
</style>
