---
import { withBase } from "../lib/paths.js";
import { formatDateLong } from "../lib/reports.js";

const { feed, latestReport, totalReports } = Astro.props;
---

<article class="feed-card panel" style={`--feed-accent: ${feed.accent};`}>
  <div class="feed-card__top">
    <span class="feed-card__badge">{feed.badge}</span>
    <span class="meta-pill">{totalReports} sayı</span>
  </div>

  <h3>{feed.shortTitle}</h3>
  <p>{feed.description}</p>

  <!-- <div class="feed-card__meta">
    <span>Otomasyon: {feed.automationName}</span>
    <span>Klasör: <code>{feed.directory}</code></span>
  </div> -->

  {
    latestReport && (
      <a class="feed-card__latest" href={withBase(latestReport.route)}>
        <small>En yeni sayı</small>
        <span class="feed-card__issue">Sayı {latestReport.issueNumber}</span>
        <strong>{latestReport.title}</strong>
        <span class="feed-card__date">{formatDateLong(latestReport.date)}</span>
      </a>
    )
  }

  <div class="button-row">
    <a class="button button--primary" href={withBase(`kaynak/${feed.id}/`)}
      >Akışı Aç</a
    >
    <!-- <a class="button" href={withBase(`kaynak/${feed.id}/rss.xml`)}>RSS</a> -->
  </div>
</article>

<style>
  .feed-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-color: rgba(255, 255, 255, 0.06);
    background:
      radial-gradient(
        ellipse at top right,
        color-mix(in srgb, var(--feed-accent) 6%, transparent),
        transparent 60%
      ),
      var(--panel);
    transition:
      border-color 250ms ease,
      transform 250ms ease,
      box-shadow 250ms ease;
  }

  .feed-card:hover {
    border-color: color-mix(
      in srgb,
      var(--feed-accent) 25%,
      rgba(255, 255, 255, 0.12)
    );
    transform: translateY(-2px);
    box-shadow:
      0 0 40px color-mix(in srgb, var(--feed-accent) 8%, transparent),
      var(--shadow);
  }

  .feed-card__top,
  .feed-card__meta {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .feed-card__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    color: #fff;
    background: color-mix(in srgb, var(--feed-accent) 80%, rgba(0, 0, 0, 0.2));
    letter-spacing: 0.02em;
  }

  .feed-card h3 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-strong);
  }

  .feed-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .feed-card__meta {
    color: var(--muted);
    font-size: 0.85rem;
  }

  .feed-card__latest {
    display: grid;
    gap: 0.3rem;
    padding: 1rem;
    border-radius: var(--radius-md);
    background: var(--surface);
    border: 1px solid var(--line);
    transition:
      border-color 200ms ease,
      background 200ms ease;
  }

  .feed-card__latest:hover {
    border-color: var(--line-strong);
    background: var(--surface-hover);
  }

  .feed-card__latest small {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.68rem;
    font-weight: 600;
  }

  .feed-card__latest strong {
    font-size: 0.98rem;
    color: var(--text-strong);
    line-height: 1.3;
  }

  .feed-card__issue {
    color: color-mix(in srgb, var(--feed-accent) 85%, white 15%);
    font-weight: 700;
    font-size: 0.85rem;
  }

  .feed-card__date {
    color: var(--muted);
    font-size: 0.82rem;
  }

  code {
    font-size: 0.82rem;
  }
</style>
