---
import { withBase } from "../lib/paths.js";
import { formatDateLong } from "../lib/reports.js";

const { feed, latestReport, totalReports } = Astro.props;
---

<article class="feed-card" style={`--feed-accent: ${feed.accent};`}>
  <div class="feed-card__top">
    <span class="feed-card__badge">{feed.badge}</span>
    <span class="meta-pill">{totalReports} sayı</span>
  </div>

  <h3>{feed.shortTitle}</h3>
  <p>{feed.description}</p>

  {
    latestReport && (
      <a class="feed-card__latest" href={withBase(latestReport.route)}>
        <small>En yeni sayı</small>
        <span class="feed-card__issue">Sayı {latestReport.issueNumber}</span>
        <strong>{latestReport.title}</strong>
        <span class="feed-card__date">{formatDateLong(latestReport.date)}</span>
      </a>
    )
  }

  <div class="button-row">
    <a class="button button--primary" href={withBase(`kaynak/${feed.id}/`)}
      >Akışı Aç</a
    >
  </div>
</article>

<style>
  .feed-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-left: 4px solid transparent;
    transition: border-color 200ms ease, background 200ms ease;
  }

  .feed-card:hover {
    border-left-color: var(--feed-accent);
    background: var(--surface);
  }

  .feed-card__top {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .feed-card__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.65rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--bg);
    background: var(--feed-accent);
  }

  .feed-card h3 {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
  }

  .feed-card p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.9rem;
  }

  .feed-card__latest {
    display: grid;
    gap: 0.3rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    transition: border-color 200ms ease;
  }

  .feed-card__latest:hover {
    border-color: var(--outline);
  }

  .feed-card__latest small {
    font-family: "Space Grotesk", sans-serif;
    color: var(--outline);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .feed-card__latest strong {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.3;
  }

  .feed-card__issue {
    color: var(--feed-accent);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
  }

  .feed-card__date {
    color: var(--text-secondary);
    font-size: 0.8rem;
  }
</style>
