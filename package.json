{
  "name": "bulten",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.0",
  "description": "Federated, AI-curated, fully static newsletter surface for daily radar markdown files.",
  "scripts": {
    "generate:pages": "node ./scripts/generate-article-pages.mjs",
